body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background: #f4f7f6; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
.container { background: white; padding: 30px; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); width: 350px; text-align: center; }
input { width: 90%; padding: 12px; margin: 10px 0; border: 1px solid #ddd; border-radius: 6px; }
button { width: 100%; padding: 12px; background: #13aa52; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold; }
button:hover { background: #118d44; }
.secondary { background: #001e2b; margin-top: 10px; }

